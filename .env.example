# Required: Ethereum address to receive payments (Base Sepolia testnet)
RECIPIENT_ADDRESS=0xYOUR_WALLET_ADDRESS_HERE

# Network: base-sepolia (testnet) or base (mainnet)
NETWORK=base-sepolia

# x402 facilitator URL
FACILITATOR_URL=https://facilitator.x402.rs

# Gateway port
PORT=8091

# Path to routes config
GATEWAY_CONFIG=./config/routes.yaml

# Optional: Redis for response caching
# REDIS_URL=redis://localhost:6379
